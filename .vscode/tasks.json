{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "MSVC: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}",
                "ws2_32.lib",
                "mswsock.lib"
            ],
            "group": "build"
        }
    ]
}