namespace highp.protocol;

enum MessageType : ushort {
	None = 0,

	// Client->Server (1-99)
	CS_JoinRoom = 1,
	CS_LeaveRoom = 2,
	CS_SendMessage = 3,

	// Server->Client (100-199)
	SC_UserJoined = 100,
	SC_UserLeft = 101,
    SC_ChatMessage = 102,

    // Errors (500+)
	SC_Error = 999
}

/*
	채팅서버의 모든 에러 코드.
*/
enum ErrorCode : ushort {
	None = 0,
    InvalidMessage = 1,
    ServerError = 99
}

enum UserStatus : byte {
    Offline = 0,
    Online = 1,
    InRoom = 2,
    Away = 3
}